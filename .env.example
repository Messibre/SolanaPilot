# SolanaPilot Configuration Example
# Copy to .env and fill in your actual keys
# NEVER commit .env to git — see .gitignore

# 🤖 Gemini API Key (REQUIRED)
# Get free key at: https://aistudio.google.com
# Starts with: AIza...
GEMINI_API_KEY=AIza_YOUR_KEY_HERE_XXXXXXXXXXXXX

# 🔗 Solana RPC Endpoint (Optional, for devnet)
# Default uses public Solana RPC (no key needed)
# For better performance, get Helius key at: https://www.helius.xyz
HELIUS_API_KEY=YOUR_HELIUS_KEY_HERE_XXXXXXXXXXXXX

# 📍 Solana Devnet RPC URL
# Public: https://api.devnet.solana.com
# Helius: https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# 🌐 Network Configuration
SOLANA_NETWORK=devnet
NODE_ENV=development
