{
  "name": "solana-copilot",
  "displayName": "SolanaPilot — AI Copilot for Solana Development",
  "description": "AI-powered Solana smart contract generator with devnet deployment and React frontend scaffolding.",
  "version": "1.0.0",
  "publisher": "solana-copilot",
  "license": "MIT",
  "keywords": [
    "solana",
    "blockchain",
    "web3",
    "anchor",
    "smart-contract",
    "ai",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/solana-copilot/solanapilot"
  },
  "bugs": {
    "url": "https://github.com/solana-copilot/solanapilot/issues"
  },
  "galleryBanner": {
    "color": "#9945FF",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:solanaCopilot.openChat",
    "onCommand:solanaCopilot.setApiKey",
    "onCommand:solanaCopilot.generateProgram",
    "onCommand:solanaCopilot.deployToDevnet",
    "onCommand:solanaCopilot.generateFrontend"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "solanaCopilot.openChat",
        "title": "Open Chat",
        "category": "SolanaPilot",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "solanaCopilot.setApiKey",
        "title": "Set Gemini API Key",
        "category": "SolanaPilot"
      },
      {
        "command": "solanaCopilot.generateProgram",
        "title": "Generate Smart Contract",
        "category": "SolanaPilot",
        "icon": "$(sparkle)"
      },
      {
        "command": "solanaCopilot.deployToDevnet",
        "title": "Deploy to Devnet",
        "category": "SolanaPilot",
        "icon": "$(rocket)"
      },
      {
        "command": "solanaCopilot.generateFrontend",
        "title": "Generate React Frontend",
        "category": "SolanaPilot",
        "icon": "$(browser)"
      }
    ],
    "keybindings": [
      {
        "command": "solanaCopilot.openChat",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "solanaCopilot.generateProgram",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "SolanaPilot",
      "properties": {
        "solanaPilot.autoContextRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh workspace context on each message"
        },
        "solanaPilot.maxHistoryMessages": {
          "type": "number",
          "default": 10,
          "description": "Number of conversation turns to keep in context"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.18.0",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "esbuild": "^0.19.5",
    "eslint": "^8.51.0",
    "typescript": "^5.2.2"
  },
  "icon": "assets/icon.png",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@google/generative-ai": "^0.3.0",
    "@solana/web3.js": "^1.95.0"
  }
}
